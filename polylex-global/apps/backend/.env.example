# Environment — Backend
# Copy this file to .env and fill in the values

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://polylex:polylex@localhost:5434/polylex"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6388"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_DEMO_EXPIRES_IN="7d"

# ─── OpenAI (Optional) ───────────────────────────────────────────────────────
OPENAI_ENABLED="false"
OPENAI_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── Zalo Mini App (Optional) ────────────────────────────────────────────────
ZALO_APP_ID=""
ZALO_APP_SECRET=""
