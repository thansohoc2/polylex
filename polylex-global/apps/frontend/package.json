{
  "name": "@polylex/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:capacitor": "tsc && vite build --mode capacitor",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:ios": "npm run build:capacitor && cap sync && cap open ios",
    "cap:open:android": "npm run build:capacitor && cap sync && cap open android",
    "cap:run:ios": "npm run build:capacitor && cap sync && cap run ios",
    "ios:fix": "rm -rf ~/Library/Developer/Xcode/DerivedData && npx cap sync ios",
    "cap:run:android": "npm run build:capacitor && cap sync && cap run android",
    "generate:pwa-icons": "pwa-assets-generator --config pwa-assets.config.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "postinstall": "node -e \"const fs=require('fs'),base='node_modules/@codetrix-studio/capacitor-google-auth';if(fs.existsSync(base)){const pkgSrc='patches/capacitor-google-auth-Package.swift',pkgDst=base+'/Package.swift';if(!fs.existsSync(pkgDst)){fs.copyFileSync(pkgSrc,pkgDst);console.log('✔ Patched capacitor-google-auth: added Package.swift');}const plgSrc='patches/capacitor-google-auth-Plugin.swift',plgDst=base+'/ios/Plugin/Plugin.swift';fs.copyFileSync(plgSrc,plgDst);console.log('✔ Patched capacitor-google-auth: updated Plugin.swift');}\" 2>/dev/null || true"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-updater": "^8.43.9",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@polylex/shared-types": "*",
    "@polylex/shared-ui": "*",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.0",
    "i18next": "^25.8.13",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0"
  }
}
