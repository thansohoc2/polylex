# Deploy environment — vars used by docker-compose.deploy.yml for ${VAR} substitution.
# Copy this to .env.deploy on the server (or CI copies it automatically).
#
# NOTE: Backend secrets (JWT, API keys, etc.) live in apps/backend/.env which is
# committed to the repo and loaded by the backend container via env_file.

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=polylex
POSTGRES_USER=polylex
POSTGRES_PASSWORD=change-me

# ── Backend runtime (overrides only) ───────────────────────────────────────
NODE_ENV=production
OPENAI_ENABLED=false

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://polylex:polylex@localhost:5434/polylex"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6388"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="Bp5R4X8ZC_qGdJSahzc3s2mRKXC9M0mVIVyODcykTSUO6E3wbSzFi0ZF7AJvg3Vf"
JWT_REFRESH_SECRET="292Qaiq0LsMnic7qDFEBjttFxPxl9LjjgMrUPFk8lTDb54gwhH_IxR_b6tAljzTa"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Gemini AI (Optional) ────────────────────────────────────────────
GEMINI_ENABLED="true"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV="production"

# AI Translation Service API Keys
# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Get Gemini API key from: https://makersuite.google.com/app/apikey  
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

GOOGLE_TTS_ENABLED="true"

GOOGLE_TTS_CREDENTIALS='{
  "type": "service_account",
  "project_id": "your-project-id",
  "private_key_id": "your-private-key-id",
  "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n",
  "client_email": "your-service-account@your-project.iam.gserviceaccount.com",
  "client_id": "your-client-id",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}'
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://media.ebms.store
GOOGLE_CLIENT_ID_WEB=944187422965-egt4gq5sr3aprq4dari21evgcffh6gjd.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=944187422965-1ri8qpj8s90fh8vfjdpis48fe8vjppg5.apps.googleusercontent.com


# ── Frontend build-time (Vite bakes these into the bundle) ─────────
VITE_API_BASE_URL=https://ebms.store/api/v1
VITE_GOOGLE_CLIENT_ID_WEB=944187422965-egt4gq5sr3aprq4dari21evgcffh6gjd.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID_IOS=944187422965-1ri8qpj8s90fh8vfjdpis48fe8vjppg5.apps.googleusercontent.com
